package com.p2p.lending.domain.decorator;

/**
 * Decorator Pattern - Abstract Decorator
 * Semua decorator extends class ini.
 */
public abstract class LoanDecorator implements LoanComponent {

    protected final LoanComponent loan;

    public LoanDecorator(LoanComponent loan) {
        this.loan = loan;
    }

    @Override
    public double getCost() {
        return loan.getCost();
    }

    @Override
    public String getDescription() {
        return loan.getDescription();
    }
}
