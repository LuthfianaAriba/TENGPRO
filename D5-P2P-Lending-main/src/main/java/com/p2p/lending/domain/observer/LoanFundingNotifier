package com.p2p.lending.domain.observer;

import com.p2p.lending.domain.model.Loan;
import java.util.ArrayList;
import java.util.List;

public class LoanFundingNotifier {

    private static final LoanFundingNotifier INSTANCE = new LoanFundingNotifier();
    private final List<LoanFundingObserver> observers = new ArrayList<>();

    private LoanFundingNotifier() {}

    public static LoanFundingNotifier getInstance() {
        return INSTANCE;
    }

    public void addObserver(LoanFundingObserver observer) {
        observers.add(observer);
    }

    public void removeObserver(LoanFundingObserver observer) {
        observers.remove(observer);
    }

    public void notifyFullyFunded(Loan loan) {
        for (LoanFundingObserver observer : observers) {
            observer.onLoanFullyFunded(loan);
        }
    }

    // Tambahan — untuk reset antar test
    public void clearObservers() {
        observers.clear();
    }
}
