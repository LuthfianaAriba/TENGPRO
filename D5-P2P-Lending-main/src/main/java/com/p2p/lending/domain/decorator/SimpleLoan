package com.p2p.lending.domain.decorator;

/**
 * Decorator Pattern - Concrete Component
 * Loan dasar dengan biaya pokok saja.
 */
public class SimpleLoan implements LoanComponent {

    private final double baseCost;
    private final String description;

    public SimpleLoan(double baseCost, String description) {
        if (baseCost <= 0) throw new IllegalArgumentException("Base cost harus lebih dari 0");
        this.baseCost = baseCost;
        this.description = description;
    }

    @Override
    public double getCost() {
        return baseCost;
    }

    @Override
    public String getDescription() {
        return "Base Cost: " + baseCost + " | " + description;
    }
}
