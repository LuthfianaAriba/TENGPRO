package com.p2p.lending.domain.decorator;

/**
 * Decorator Pattern - Concrete Decorator
 * Mengurangi biaya loan dengan cashback.
 */
public class CashbackDecorator extends LoanDecorator {

    private final double cashback;

    public CashbackDecorator(LoanComponent loan, double cashback) {
        super(loan);
        if (cashback < 0) throw new IllegalArgumentException("Cashback tidak boleh negatif");
        this.cashback = cashback;
    }

    @Override
    public double getCost() {
        return loan.getCost() - cashback;
    }

    @Override
    public String getDescription() {
        return loan.getDescription() + " - Cashback: " + cashback;
    }
}
